# Copy this file to .env.local and fill in your own key(s).
# Vite only exposes env vars prefixed with VITE_ to client code.

# YouTube Data API v3 key, used for real YouTube Music search.
# Get one from https://console.cloud.google.com/apis/credentials after
# enabling the "YouTube Data API v3" for a project. No OAuth needed for
# search — playback then uses the YouTube IFrame Player API, which needs
# no key at all.
VITE_YOUTUBE_API_KEY=
